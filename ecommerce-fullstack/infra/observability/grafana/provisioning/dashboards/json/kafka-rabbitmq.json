{
  "uid": "shopmax-messaging",
  "title": "Kafka and RabbitMQ",
  "tags": ["shopmax", "kafka", "rabbitmq"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Kafka topics (published by API)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_messages_published_total[1m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "RabbitMQ publish/consume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (queue) (rate(rabbitmq_messages_published_total[1m]))",
          "legendFormat": "pub {{queue}}"
        },
        {
          "expr": "sum by (queue) (rate(rabbitmq_messages_consumed_total[1m]))",
          "legendFormat": "con {{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Kafka broker topics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kafka_topic_partitions)",
          "legendFormat": "partitions"
        }
      ]
    },
    {
      "id": 4,
      "title": "RabbitMQ queue messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_queue_messages)",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
