{
  "uid": "shopmax-logs",
  "title": "Logs Explorer",
  "tags": ["shopmax", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Kafka container logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*kafka.*\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 2,
      "title": "RabbitMQ container logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*rabbitmq.*\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "title": "IA structured logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*ecommerce-ia.*\"} |= \"service\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
