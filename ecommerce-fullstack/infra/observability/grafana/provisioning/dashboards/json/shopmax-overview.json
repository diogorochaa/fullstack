{
  "uid": "shopmax-overview",
  "title": "Shopmax Overview",
  "tags": ["shopmax", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "API request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"ecommerce-api\"}[1m]))",
          "legendFormat": "API RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "IA request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"ecommerce-ia\"}[1m]))",
          "legendFormat": "IA RPS"
        }
      ]
    },
    {
      "id": 3,
      "title": "API 5xx errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"ecommerce-api\",status=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka messages published",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_messages_published_total[5m]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "RabbitMQ messages published",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rabbitmq_messages_published_total[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Scrape targets up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(up)"
        }
      ]
    }
  ]
}
