      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PostgreSQL :5432 (Prisma + SQLAlchemy)  |  Redis :6379 (sessões IA — roadmap)  |  RabbitMQ :5672 / UI :15672\nKafka :9092 + Zookeeper :2181\n\nFilas RabbitMQ: orders.fulfillment | ia.reindex | payments.webhook\nTópicos Kafka: product.* | order.* | payment.paid | payment.failed",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PostgreSQL :5432 (Prisma + SQLAlchemy)  |  Redis :6379 (sessões IA — roadmap)  |  RabbitMQ :5672 / UI :15672\nKafka :9092 + Zookeeper :2181\n\nFilas RabbitMQ: orders.fulfillment | ia.reindex | payments.webhook\nTópicos Kafka: product.* | order.* | payment.paid | payment.failed",
      "lineHeight": 1.25
    },
