    {
      "id": "api-content",
      "type": "text",
      "x": 400,
      "y": 130,
      "width": 290,
      "height": 330,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": ["api"],
      "frameId": null,
      "roundness": null,
      "seed": 7,
      "version": 1,
      "versionNonce": 7,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "NestJS + Prisma + PostgreSQL\nClean Architecture por módulo\n\nZod: env validation\nclass-validator: DTOs HTTP\nGlobalExceptionFilter\nSwagger /api/docs (dev)\nJWT + refresh rotation\n\nDomainEventsService:\n├ Kafka emit (event log)\n├ RabbitMQ publish (jobs)\n└ Socket.IO broadcast\n\nMódulos: auth, users,\ncategories, products, cart,\naddresses, orders,\npayments, admin",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NestJS + Prisma + PostgreSQL\nClean Architecture por módulo\n\nZod: env validation\nclass-validator: DTOs HTTP\nGlobalExceptionFilter\nSwagger /api/docs (dev)\nJWT + refresh rotation\n\nDomainEventsService:\n├ Kafka emit (event log)\n├ RabbitMQ publish (jobs)\n└ Socket.IO broadcast\n\nMódulos: auth, users,\ncategories, products, cart,\naddresses, orders,\npayments, admin",
      "lineHeight": 1.25
    },
