      "versionNonce": 16,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. Admin CRUD produto → Kafka product.* + Rabbit ia.reindex → IA reindexa Chroma\n2. Criar pedido → Kafka order.created + Rabbit orders.fulfillment → consumer API + Socket order:created/fulfillment → UI toast\n3. Admin muda status → Kafka order.status.changed + Socket order:status → UI\n4. Pagamento/webhook → Kafka payment.paid/failed + Rabbit payments.webhook + Socket payment:updated",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Admin CRUD produto → Kafka product.* + Rabbit ia.reindex → IA reindexa Chroma\n2. Criar pedido → Kafka order.created + Rabbit orders.fulfillment → consumer API + Socket order:created/fulfillment → UI toast\n3. Admin muda status → Kafka order.status.changed + Socket order:status → UI\n4. Pagamento/webhook → Kafka payment.paid/failed + Rabbit payments.webhook + Socket payment:updated",
      "lineHeight": 1.25
    },
