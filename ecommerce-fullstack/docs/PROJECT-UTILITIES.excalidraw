    {
      "id": "ia-content",
      "type": "text",
      "x": 780,
      "y": 130,
      "width": 270,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": ["ia"],
      "frameId": null,
      "roundness": null,
      "seed": 10,
      "version": 1,
      "versionNonce": 10,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "FastAPI + LangGraph\nOpenAI gpt-4o-mini\n\nRAG: Chroma + FAQ .md\nTools: search/get products\n\nKafka consumer:\nproduct.created/updated/deleted\n→ reindex Chroma\n\nRabbitMQ consumer:\nia.reindex queue\n\nSocket.IO: chat:message\nPOST /chat (REST)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FastAPI + LangGraph\nOpenAI gpt-4o-mini\n\nRAG: Chroma + FAQ .md\nTools: search/get products\n\nKafka consumer:\nproduct.created/updated/deleted\n→ reindex Chroma\n\nRabbitMQ consumer:\nia.reindex queue\n\nSocket.IO: chat:message\nPOST /chat (REST)",
      "lineHeight": 1.25
    },
