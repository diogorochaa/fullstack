#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
fi
# cmd-shim-target=/home/desenvolvedor23/projetos/DFR/api-clean-arch-node/.pnpm-store/v11/links/@/pnpm/11.9.0/92bb10372f62db71cbc98af38930d00b053c41d2580dc6358198bb66fe9b65f4/node_modules/pnpm/bin/pnpx.mjs
